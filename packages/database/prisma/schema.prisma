generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  AVAILABLE
  RESERVED
  SOLD
  REFUNDED
  DISABLED
  EXPIRED
  PENDING_VERIFICATION
  WAITING_SUPPLIER
  LOST
}

enum RoleType {
  OWNER
  ADMINISTRATOR
  MANAGER
  STAFF
  VIEWER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         RoleType @default(VIEWER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditLogs    AuditLog[]
  activityLogs ActivityLog[]

  @@map("users")
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  email         String?
  trustScore    Int      @default(100) @map("trust_score")
  isBlacklisted Boolean  @default(false) @map("is_blacklisted")
  balance       Decimal  @default(0.00) @db.Decimal(10, 2)
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  accounts Account[]

  @@map("suppliers")
}

model Account {
  id                String        @id @default(uuid())
  internalId        String        @unique @map("internal_id")
  platform          String
  category          String
  email             String
  password          String
  recoveryEmail     String?       @map("recovery_email")
  recoveryPassword  String?       @map("recovery_password")
  username          String?
  twoFactorStatus   Boolean       @default(false) @map("two_factor_status")
  purchasePrice     Decimal       @db.Decimal(10, 2) @map("purchase_price")
  expectedSalePrice Decimal       @db.Decimal(10, 2) @map("expected_sale_price")
  actualSalePrice   Decimal?      @db.Decimal(10, 2) @map("actual_sale_price")
  status            AccountStatus @default(PENDING_VERIFICATION)
  version           Int           @default(1)

  supplierId String?   @map("supplier_id")
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("accounts")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entity     String
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  deviceInfo String?  @map("device_info")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}
